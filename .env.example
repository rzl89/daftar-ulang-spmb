# Environment Variables Configuration

# Copy this file to .env and fill in the actual values

# 1. Database Configuration (Neon / PostgreSQL)
# Example: postgresql://username:password@hostname/dbname?sslmode=require
DATABASE_URL=

# 2. VITE Cloudinary Configuration (For frontend uploads)
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_API_KEY=

# 3. Cloudinary Backend Configuration (For generating upload signatures)
CLOUDINARY_API_SECRET=

# 4. JWT Secret Key (REQUIRED — generate with: openssl rand -hex 64)
SECRET_KEY=

# 5. Allowed Origins for CORS (comma-separated, e.g. https://example.com,http://localhost:5173)
ALLOWED_ORIGINS=
