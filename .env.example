# Environment Variables Configuration

# Copy this file to .env and fill in the actual values

# 1. Database Configuration (Neon / PostgreSQL)
# Example: postgresql://username:password@hostname/dbname?sslmode=require
DATABASE_URL=

# 2. VITE Cloudinary Configuration (For frontend uploads)
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_API_KEY=

# 3. Cloudinary Backend Configuration (For generating upload signatures)
CLOUDINARY_API_SECRET=

# 4. JWT Secret Key (REQUIRED — generate with: openssl rand -hex 64)
SECRET_KEY=

# 5. Default Admin Password (optional — used during database seed)
# If not set, a random password will be generated and logged to console
DEFAULT_ADMIN_PASSWORD=

# 6. Allowed Origins for CORS (comma-separated)
# Example: https://example.com,http://localhost:5173
ALLOWED_ORIGINS=

# 7. Node Environment (production | development)
NODE_ENV=development

# 8. Server Port (default: 3000, only used when not on Vercel)
PORT=3000
